# Firebase Cloud Functions Environment Variables Template
# Copy this file to .env and update with your values

# Private bucket where aes_key.bin is stored
# Common options: dream-pedi-secrets, dream-pedi.firebasestorage.app, dreamprod
TEXTBOOK_KEY_BUCKET=dream-pedi-secrets

# Path to the AES key file within the bucket
TEXTBOOK_KEY_PATH=aes_key.bin
