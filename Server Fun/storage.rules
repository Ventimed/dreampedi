rules_version = '2';

// Firebase Storage Security Rules for Dream Pediatrics
service firebase.storage {
  match /b/{bucket}/o {
    
    // Public read access for textbooks folder
    // Anyone can download encrypted textbook files
    match /textbooks/{allPaths=**} {
      allow read: if true;      // Public read access
      allow write: if false;    // No public write access
    }
    
    // Public read access for images folder
    match /images/{allPaths=**} {
      allow read: if true;      // Public read access
      allow write: if false;    // No public write access
    }
    
    // Authenticated users only for other files
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
