<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">

    <!-- size is optional; can be overridden by view padding/layout -->
    <size android:width="40dp" android:height="40dp"/>

    <!-- Use theme primary color (falls back if not available) -->
    <solid android:color="#FFF8E1" />

    <!-- thin border to separate from background -->
    <stroke android:width="1dp" android:color="@android:color/transparent" />

    <!-- fully rounded by being an oval shape -->
    <corners android:radius="20dp"/>
</shape>
