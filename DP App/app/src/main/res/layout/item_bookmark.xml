<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    android:foreground="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:layout_marginHorizontal="16dp"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="?attr/colorSurfaceVariant">

        <TextView
            android:id="@+id/bookmarkTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bookmark Title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="8dp"
            android:lineHeight="24sp" />

        <TextView
            android:id="@+id/bookmarkSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chapter and Section Info"
            android:textSize="16sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="8dp"
            android:lineHeight="22sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="invisible"
            android:gravity="center_vertical">

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/dot_indicator"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/bookmarkInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bookmarked 3 days ago • High Priority"
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurfaceVariant" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>