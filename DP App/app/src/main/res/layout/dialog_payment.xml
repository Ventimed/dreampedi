<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:gravity="center">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/dialog_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardUseCompatPadding="true"
        app:strokeColor="#22000000"
        app:strokeWidth="0dp"
        android:foreground="?android:attr/selectableItemBackground">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/form_container"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <TextView
                    android:id="@+id/dialogTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Complete Purchase"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/dialogSub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="300Br"
                    android:textSize="18dp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginTop="4dp" />

                <LinearLayout
                    android:id="@+id/payment_top"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Choose payment option"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="14sp" />

                    <!-- RadioGroup contains rows (wrapper LinearLayouts). RadioButtons keep their ids so selection works. -->
                    <RadioGroup
                        android:id="@+id/rgOptions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="8dp">

                        <!-- Row: CBE -->
                        <LinearLayout
                            android:id="@+id/row_rbBank"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="8dp"
                            android:gravity="center_vertical">

                            <ImageView
                                android:id="@+id/iv_rbBank"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_marginEnd="12dp"
                                android:contentDescription="bank icon"
                                android:src="@drawable/ic_cbe" />

                            <RadioButton
                                android:id="@+id/rbBank"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="CBE"
                                android:textSize="16dp"
                                android:textStyle="bold"
                                android:textColor="#000000"/>
                        </LinearLayout>

                        <!-- Row: telebirr -->
                        <LinearLayout
                            android:id="@+id/row_rbMpesa"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="8dp"
                            android:gravity="center_vertical">

                            <ImageView
                                android:id="@+id/iv_rbtelebirr"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_marginEnd="12dp"
                                android:contentDescription="telebirr icon"
                                android:src="@drawable/ic_tele" />

                            <RadioButton
                                android:id="@+id/rbtele"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="telebirr"
                                android:textSize="16dp"
                                android:textStyle="bold"
                                android:textColor="#000000" />
                        </LinearLayout>

                        <!-- Row: E-Birr -->
                        <LinearLayout
                            android:id="@+id/row_rbPaypal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="8dp"
                            android:gravity="center_vertical">

                            <ImageView
                                android:id="@+id/iv_rbEbirr"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_marginEnd="12dp"
                                android:contentDescription="ebirr icon"
                                android:src="@drawable/ic_ebirr" />

                            <RadioButton
                                android:id="@+id/rbebirr"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="E-Birr"
                                android:textSize="16dp"
                                android:textStyle="bold"
                                android:textColor="#000000" />
                        </LinearLayout>

                    </RadioGroup>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="12dp" />

                    <LinearLayout
                        android:orientation="vertical"
                        android:padding="8dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/rounded_bg_light_blue">

                        <TextView
                            android:id="@+id/tvAccountNameLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Account name"
                            android:textSize="12sp"
                            android:textColor="#000000" />

                        <TextView
                            android:id="@+id/tvAccountName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"
                            android:textColor="#000000"  />

                        <TextView
                            android:id="@+id/tvAccountNumberLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Account / Number"
                            android:textSize="12sp"
                            android:layout_marginTop="8dp"
                            android:textColor="#000000"  />

                        <TextView
                            android:id="@+id/tvAccountNumber"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:layout_marginTop="4dp"
                            android:textStyle="italic"
                            android:textColor="#000000"  />

                    </LinearLayout>

                    <RadioButton
                        android:id="@+id/paid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="I have Paid"
                        android:layout_marginTop="12dp"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold"/>
                </LinearLayout>
                <!-- Transaction form -->
                <LinearLayout
                    android:id="@+id/payment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Transaction ID"
                        android:textSize="16dp"
                        android:textStyle="bold"/>

                    <EditText
                        android:id="@+id/etTxId"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="e.g. FT26CVxxxxxx"
                        android:layout_marginTop="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your name (as on receipt)"
                        android:layout_marginTop="10dp"
                        android:textSize="16dp"
                        android:textStyle="bold"/>

                    <EditText
                        android:id="@+id/etPayerName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Full name"
                        android:layout_marginTop="6dp" />

                    <TextView
                        android:id="@+id/tvError"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#DD4444"
                        android:visibility="gone"
                        android:layout_marginTop="8dp"
                        android:text="" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <Button
                            android:id="@+id/btnSubmit"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Submit" />

                        <Button
                            android:id="@+id/btnCancel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cancel"
                            android:layout_marginStart="8dp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/please_wait"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ProgressBar
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        style="?android:attr/progressBarStyleLarge" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thank you for submission — please wait..."
                        android:layout_marginTop="12dp"
                        android:textColor="?attr/colorOnSurface" />

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/thank_you"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Payment received"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"  />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thanks — we will verify your payment and unlock access shortly."
                    android:layout_marginTop="8dp"
                    android:textColor="?attr/colorOnSurface" />

                <Button
                    android:id="@+id/btnClose"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Close"
                    android:layout_marginTop="12dp" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
