<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Greeting Section with Subscribe Card / Goal Pill -->
        <LinearLayout
            android:id="@+id/greetingSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/primary"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="22dp">

            <TextView
                android:id="@+id/greetingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Good afternoon,\nDr. Nati"
                android:textColor="@color/on_primary_dark"
                android:textStyle="bold"
                android:textSize="24sp"
                android:lineHeight="28sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/greetingTimeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ready for today's session?"
                android:textColor="@color/on_primary"
                android:textSize="14sp"
                android:layout_marginBottom="14dp" />

            <!-- Subscribe Card (shown when not verified) -->
            <LinearLayout
                android:id="@+id/subscribeCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_goal_pill"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:visibility="gone">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_crown"
                    android:tint="@color/on_primary_dark"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Unlock full access"
                        android:textSize="13sp"
                        android:textColor="@color/on_primary_dark"
                        android:alpha="0.7" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Subscribe to all chapters"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_primary_dark"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSubscribe"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Subscribe"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:backgroundTint="#FFFFFF"
                    android:textColor="@color/on_primary_dark"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    app:cornerRadius="10dp"
                    android:elevation="0dp"
                    app:elevation="0dp" />
            </LinearLayout>

            <!-- Download Card (shown when verified but not downloaded) -->
            <LinearLayout
                android:id="@+id/downloadCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_goal_pill"
                android:padding="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_download"
                        android:tint="@color/on_primary_dark"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ready to download"
                            android:textSize="13sp"
                            android:textColor="@color/on_primary_dark"
                            android:alpha="0.7" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Download textbook content"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_primary_dark"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDownload"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Download"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:backgroundTint="#FFFFFF"
                        android:textColor="@color/on_primary_dark"
                        android:paddingStart="24dp"
                        android:paddingEnd="24dp"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp"
                        app:cornerRadius="10dp"
                        android:elevation="0dp"
                        app:elevation="0dp" />
                </LinearLayout>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/downloadProgressBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:indeterminate="false"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    app:indicatorColor="@color/on_primary_dark"
                    app:trackColor="@color/goal_pill_bg_alpha" />
            </LinearLayout>

            <!-- Goal Pill (Streak Card - shown when verified and downloaded) -->
            <LinearLayout
                android:id="@+id/streakCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_goal_pill"
                android:padding="10dp"
                android:gravity="center_vertical"
                android:visibility="gone">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_fire"
                    android:layout_marginEnd="10dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Today's reading goal"
                        android:textSize="13sp"
                        android:textColor="@color/on_primary" />

                    <TextView
                        android:id="@+id/goalValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2 of 3 topics done"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_primary_container"
                        android:layout_marginTop="1dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/goalStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥 5-day streak"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_primary_dark"
                    android:background="@drawable/bg_goal_streak"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />
            </LinearLayout>
        </LinearLayout>
        <!-- Section Header with Continue Reading Button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="14dp"
            android:layout_marginHorizontal="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Chapters"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface" />

            <LinearLayout
                android:id="@+id/btnContinue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_continue_button"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▶"
                    android:textSize="12sp"
                    android:textColor="@color/on_surface"
                    android:layout_marginEnd="5dp" />

                <TextView
                    android:id="@+id/chipText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Continue reading"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface" />
            </LinearLayout>
        </LinearLayout>
        <!-- Chapters Container -->
        <LinearLayout
            android:id="@+id/chaptersContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="8dp"/>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
