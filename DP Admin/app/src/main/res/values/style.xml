<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- App styles -->
    <style name="Theme.AdminConsole" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary amber palette -->
        <item name="colorPrimary">@color/amber_500</item>
        <item name="colorPrimaryVariant">@color/amber_600</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="android:statusBarColor">@color/amber_600</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>

        <item name="android:navigationBarColor">@color/white_faint</item>

        <!-- For Material components -->
        <item name="materialButtonStyle">@style/Widget.AdminConsole.Button</item>
        <item name="android:windowMinWidthMajor">320dp</item>
        <item name="android:windowMinWidthMinor">320dp</item>
    </style>

    <!-- Button style used for primary save/send buttons -->
    <style name="Widget.AdminConsole.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
        <item name="elevation">6dp</item>
    </style>

    <!-- Card style convenience -->
    <style name="Widget.AdminConsole.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">8dp</item>
        <item name="cardUseCompatPadding">true</item>
    </style>
</resources>
