# =============================================================================
# Unified .gitignore for Dream Pediatrics Projects
# Covers both DreamPediatrics and DP Admin folders
# =============================================================================

# Built application files
*.apk
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
release/

# Gradle files
.gradle/
**/build/
gradle-app.setting
!gradle-wrapper.jar

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ IDEA
*.iml
.idea/
.idea/workspace.xml
.idea/tasks.xml
.idea/gradle.xml
.idea/assetWizardSettings.xml
.idea/dictionaries
.idea/libraries
.idea/caches
.idea/modules.xml
.idea/navEditor.xml
.idea/.name
.idea/compiler.xml
.idea/copyright/profiles_settings.xml
.idea/encodings.xml
.idea/misc.xml
.idea/scopes/scope_settings.xml
.idea/vcs.xml
.idea/jsLibraryMappings.xml
.idea/datasources.xml
.idea/dataSources.ids
.idea/sqlDataSources.xml
.idea/dynamic.xml
.idea/uiDesigner.xml
.idea/jarRepositories.xml

# Keystore files - NEVER commit these!
*.jks
*.keystore
keystore.properties

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild
.cxx/

# Google Services (e.g. APIs or Firebase)
# Uncomment the line below if you don't want to commit google-services.json
# google-services.json

# Freeline
freeline.py
freeline/
freeline_project_description.json

# fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output
fastlane/readme.md

# Version control
vcs.xml

# lint
lint/intermediates/
lint/generated/
lint/outputs/
lint/tmp/
lint-results*.xml
lint-results*.html

# Android Profiling
*.hprof

# =============================================================================
# Firebase & Cloud Functions (for DreamPediatrics)
# =============================================================================

# Firebase Functions
**/functions/node_modules/
**/functions/.runtimeconfig.json
**/functions/lib/
**/functions/dist/
**/functions/package-lock.json

# Firebase
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log
database-debug.log
pubsub-debug.log
firebase-debug.*.log

# =============================================================================
# Node.js (for Cloud Functions)
# =============================================================================

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Dependency directories
jspm_packages/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.test
.env.production
.env.local
.env.*.local
*.local

# =============================================================================
# Sensitive Files - NEVER COMMIT THESE!
# =============================================================================

# Encryption keys and sensitive data
aes_key.bin
textbook_encrypted.bin
textbook.json

# Firebase service accounts
service-account.json
*-firebase-adminsdk-*.json

# Admin app credentials backup
AccessToken.java.backup

# Signing files
signing/
release-keys/
credentials/
keys/
secrets/

# =============================================================================
# Operating System Files
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.directory
.Trash-*

# =============================================================================
# Backup & Temporary Files
# =============================================================================

*.bak
*.backup
*.old
*.orig
*.swp
*.swo
*~
*.tmp

# Crash logs
hs_err_pid*
replay_pid*

# =============================================================================
# Test & Coverage
# =============================================================================

test-results/
test-output/
coverage/
.nyc_output/

# =============================================================================
# Documentation
# =============================================================================

docs/_build/
site/

# Temporary files
tmp/
temp/

# =============================================================================
# Archives
# =============================================================================

*.zip
*.tar
*.tar.gz
*.rar
*.7z

# =============================================================================
# Large Media Files (uncomment if needed)
# =============================================================================

# *.mp4
# *.mov
# *.avi
# *.mkv
# *.pdf

# =============================================================================
# Android NDK
# =============================================================================

obj/

# =============================================================================
# IDE & Editor Files
# =============================================================================

# Visual Studio Code
.vscode/

# Eclipse
.project
.classpath
.settings/

# Python
*.pyc
__pycache__/

# =============================================================================
# Project-Specific (Optional)
# =============================================================================

# Uncomment if you want to ignore the cleanup guide
# CLEANUP_GUIDE.md

# Uncomment if you have local test data
# test-data/
# sample-data/
