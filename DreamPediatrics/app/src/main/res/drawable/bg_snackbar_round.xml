<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background color (adjust for dark/light themes if needed) -->
    <solid android:color="@color/snackbar" />

    <!-- Rounded corners -->
    <corners android:radius="14dp" />

    <!-- Optional subtle padding inside -->
    <padding
        android:left="12dp"
        android:top="8dp"
        android:right="12dp"
        android:bottom="8dp" />

    <!-- Optional stroke for better contrast -->
    <stroke
        android:width="1dp"
        android:color="@color/outline_variant" />

</shape>
