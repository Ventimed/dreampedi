<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/dialog_universal.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_round_bg"
    android:padding="24dp">

    <!-- Dialog Icon (optional) -->
    <ImageView
        android:id="@+id/dialogIcon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp"
        android:visibility="gone"
        android:src="@drawable/ic_info"
        app:tint="@color/primary" />

    <!-- Loading Text (matches your original loadingText ID) -->
    <TextView
        android:id="@+id/loadingText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Dialog Title"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="12dp"
        android:visibility="visible" />

    <!-- Dialog Body/Message -->
    <TextView
        android:id="@+id/dialogMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Dialog message goes here"
        android:textSize="16sp"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="20dp"
        android:alpha="0.87"
        android:visibility="visible" />

    <!-- Loading Progress Bar (matches your original loadingProgress ID) -->
    <ProgressBar
        android:id="@+id/loadingProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp"
        android:visibility="gone"
        android:indeterminate="true" />

    <!-- Button Container -->
    <LinearLayout
        android:id="@+id/buttonContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:visibility="visible">

        <!-- Negative/Cancel Button (unchanged) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/dialogNegativeButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:layout_marginEnd="12dp"
            android:visibility="visible"
            style="@style/Widget.Material3.Button.TextButton"
            android:textColor="?attr/colorOnSurface" />

        <!-- Positive/OK Button with overlay spinner -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/dialogPositiveButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OK"
                android:visibility="visible"
                android:paddingLeft="20dp"
                android:paddingRight="20dp"
                android:backgroundTint="@color/primary"
                android:textColor="@color/on_primary" />

            <!-- Circular small spinner centered on the button -->
            <ProgressBar
                android:id="@+id/dialogPositiveProgress"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:indeterminate="true"
                android:visibility="gone"
                android:indeterminateTint="@android:color/black"
                android:indeterminateTintMode="src_in"/>

        </FrameLayout>

    </LinearLayout>

</LinearLayout>