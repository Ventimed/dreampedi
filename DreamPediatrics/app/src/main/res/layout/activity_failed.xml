<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="?attr/colorSurface">

    <!-- Error Icon -->
    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_padlock"
        android:layout_marginBottom="32dp"
        app:tint="@color/error" />

    <!-- Error Title -->
    <TextView
        android:id="@+id/errorText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Account Verification Failed"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Error Details -->
    <TextView
        android:id="@+id/errorDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Device verification failed. Please login from the registered device."
        android:textSize="16sp"
        android:textColor="?attr/colorOnSurface"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        android:alpha="0.8" />

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Retry Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/logoutButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Logout From Other Devices"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"
            app:cornerRadius="8dp"
            android:backgroundTint="@color/primary"
            android:textColor="@color/on_primary" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminate="true"/>


        <!-- Contact Support Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/contactSupportButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Contact Support"
            android:textSize="16sp"
            app:cornerRadius="8dp"
            style="@style/Widget.Material3.Button.TextButton"
            android:textColor="?attr/colorOnSurface" />

    </LinearLayout>

    <!-- Info Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginHorizontal="8dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/warning"
        app:cardBackgroundColor="@color/surface_variant" >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_info"
                android:layout_marginEnd="12dp"
                app:tint="@color/warning" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Each account can only be used on one device at a time. Please ensure you're using the same device where you first registered."
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurface"
                android:alpha="0.8" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>